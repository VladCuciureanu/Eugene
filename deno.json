{
  "name": "@grief/cli",
  "version": "0.1.0",
  "tasks": {
    "dev": "deno run --allow-run --allow-env --allow-read src/main.ts",
    "test": "deno test --allow-all test/",
    "install": "deno install --allow-run --allow-env --allow-read -n grief src/main.ts"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false
  }
}
